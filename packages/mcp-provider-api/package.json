{
  "name": "@dormon/mcp-provider-api",
  "description": "API to implement a McpProvider that provides prompts, resources, and tools to be registered by an MCP server",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dormonbear/Salesforce-MCP.git",
    "directory": "packages/mcp-provider-api"
  },
  "homepage": "https://github.com/dormonbear/Salesforce-MCP",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "@salesforce/core": "^8.24.3",
    "@salesforce/ts-types": "^2",
    "@types/semver": "^7.7.1",
    "semver": "^7.7.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/node": "^22.16.5",
    "@vitest/coverage-istanbul": "^3.2.4",
    "eslint": "^9.35.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "LICENSE.txt",
    "package.json"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json --verbose",
    "clean": "tsc --build tsconfig.build.json --clean",
    "clean-all": "yarn clean && rimraf node_modules",
    "format": "prettier --write .",
    "lint": "echo 'no lint script available yet'",
    "postclean": "rimraf dist && rimraf ./*.tgz",
    "package": "yarn pack",
    "prepublishOnly": "yarn build",
    "test": "tsc --build tsconfig.json --noEmit && vitest run --coverage"
  }
}
