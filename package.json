{
  "name": "monorepo-for-salesforce-mcp-server-and-providers",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": {
    "packages": [
      "packages/mcp",
      "packages/mcp-provider-api",
      "packages/mcp-provider-dx-core",
      "packages/mcp-test-client"
    ],
    "nohoist": [
      "**"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@modelcontextprotocol/inspector": "^0.15.0",
    "rimraf": "^6.0.1"
  },
  "overrides": {
    "@salesforce/core": "^8.29.0",
    "nock": "^13.5.6"
  },
  "scripts": {
    "build": "yarn workspace @dormon/mcp-provider-api run build && yarn workspace @dormon/mcp-provider-dx-core run build && yarn workspace @dormon/salesforce-mcp run build",
    "build:all": "yarn workspaces run build",
    "clean": "yarn workspaces run clean",
    "clean-all": "yarn workspaces run clean-all && rimraf node_modules",
    "lint": "yarn workspaces run lint",
    "package": "yarn workspaces run package",
    "test": "yarn workspaces run test"
  }
}
